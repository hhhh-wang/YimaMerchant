<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yimamerchant.system.mapper.hotel.HotelFacilityMapper">

    <resultMap id="HotelFacilityResult" type="com.yimamerchant.system.domain.hotel.HotelFacility">
        <id     property="id"           column="id"/>
        <result property="facilityName" column="facility_name"/>
        <result property="facilityType" column="facility_type"/>
        <result property="status"       column="status"/>
        <result property="sortNum"      column="sort_num"/>
        <result property="remark"       column="remark"/>
    </resultMap>

    <sql id="selectFacilityColumns">
        select
            id,
            facility_name,
            facility_type,
            status,
            sort_num,
            remark
        from hotel_facility
    </sql>

    <select id="selectFacilityList"
            parameterType="com.yimamerchant.system.domain.hotel.query.HotelFacilityQuery"
            resultMap="HotelFacilityResult">
        <include refid="selectFacilityColumns"/>
        where 1 = 1
        <if test="facilityType != null and facilityType != ''">
            and facility_type = #{facilityType}
        </if>
        <if test="status != null and status != ''">
            and status = #{status}
        </if>
        order by sort_num asc, id asc
    </select>

</mapper>

